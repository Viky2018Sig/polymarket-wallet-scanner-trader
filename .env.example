# Polymarket Wallet Scanner & Paper Trader — Environment Config
# Copy this file to .env and fill in your values.

# ── Paper trading ──────────────────────────────────────────────────────────────
STARTING_BANKROLL=1000
KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.03

# ── Wallet qualification ───────────────────────────────────────────────────────
MIN_PROFIT_FACTOR=2.0
MIN_TRADES_REQUIRED=20
LOW_PRICE_MIN_PCT=0.10
MAX_DRAWDOWN_THRESHOLD=0.40

# ── Scanning ───────────────────────────────────────────────────────────────────
LOOKBACK_DAYS=90
SCAN_INTERVAL_MINUTES=30
MAX_TRACKED_WALLETS=50

# ── Telegram notifications ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Polymarket API (optional — for authenticated CLOB endpoints) ───────────────
POLYMARKET_API_KEY=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_PATH=./polymarket_scanner.db
